# Shared
AEGIS_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Backend
APP_NAME=Aegis AI
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=sqlite+aiosqlite:///./data/aegis.db
POSTGRES_DATABASE_URL=postgresql+asyncpg://aegis:aegis@postgres:5432/aegis
CHROMA_PATH=./data/chroma
UPLOAD_DIR=./data/uploads
WORKSPACE_ROOT=./workspace

# Local AI
LLM_PROVIDER=mock
LOCAL_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MODEL_DEVICE=auto
MODEL_DTYPE=auto
MAX_NEW_TOKENS=768
TEMPERATURE=0.7
TOP_P=0.9

# Tooling
COMMAND_SANDBOX_ENABLED=true
COMMAND_TIMEOUT_SECONDS=20
WEB_SEARCH_PROVIDER=disabled
MQTT_BROKER_URL=
